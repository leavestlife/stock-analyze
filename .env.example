# Optional free API keys.
# Copy this file to .env and fill only the services you want to use.

# Alpha Vantage free key: US company overview, EPS/earnings, analyst target price.
ALPHA_VANTAGE_API_KEY=

# FMP free key: US profile, quote, ratios, target consensus.
FMP_API_KEY=
FMP_API_KEY_BACKUP=

# OpenDART free key: Korea company financial statements.
DART_API_KEY=

# SEC asks automated tools to identify themselves. Use a real contact if possible.
SEC_USER_AGENT=StockLens local scanner your-email@example.com

# Supabase cloud portfolio backup. Keep the service role key server-only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PORTFOLIO_TABLE=stocklens_portfolios
